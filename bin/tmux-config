#!/usr/bin/env bash

# tmux-config: Script to manage tmux configuration using GNU stow
# Dependencies: stow, tmux
# This script handles the symlinking of tmux configuration files to the user's home directory

set -euo pipefail

# Initialize global variables
readonly CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly BIN_DIR="${XDG_BIN_HOME:-$HOME/.local/bin}"
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m' # No Color

# Default to both types if not specified
STOW_TYPE="all"

# Print usage information
usage() {
    cat << EOF
Usage: $(basename "$0") [OPTIONS]

Options:
    -t, --type TYPE    Specify what to stow: 'config', 'exec', or 'all' (default: all)
    -h, --help         Show this help message

Types:
    config    Stow configuration files to home directory
    exec      Stow executable files to ${BIN_DIR}
    all       Stow both config and executable files
EOF
}

# Print a status message with color
# Args:
#   $1 - color code
#   $* - message to print
print_status() {
    local color=$1
    shift
    printf "${color}%s${NC}\n" "$*"
}

# Check if a command exists in the system
# Args:
#   $1 - command name to check
# Returns:
#   0 if command exists, 1 otherwise
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Perform stow operation
# Args:
#   $1 - boolean: true for simulation mode, false for actual operation
# Returns:
#   0 if successful, 1 otherwise
# Outputs:
#   Stow operation results to stdout
do_stow() {
    local simulate=$1
    local success=0
    case "${STOW_TYPE}" in
        config|all)
            stow --target="${HOME}" ${simulate:+"--simulate"} --dotfiles --verbose --dir="${CONFIG_DIR}" config 2>&1 || success=1
            ;;
    esac
    
    case "${STOW_TYPE}" in
        exec|all)
            if [[ -d "${CONFIG_DIR}/bin" ]]; then
                stow --target="${BIN_DIR}" ${simulate:+"--simulate"} --verbose --dir="${CONFIG_DIR}" bin 2>&1 || success=1
            fi
            ;;
    esac
    
    return $success
}

# Get user confirmation for an action
# Args:
#   $1 - default response (Y/N)
# Returns:
#   0 if user confirms, 1 otherwise
get_user_confirmation() {
    local default=$1
    local response
    
    read -p "Do you want to proceed with the actual stow operation? (Y/n) [${default}] " response
    response=${response:-$default}
    
    [[ ${response,,} =~ ^y(es)?$ || ( ${default} == "Y" && -z "$response" ) ]]
}

# Check prerequisites before running the script
check_prerequisites() {
    if ! command_exists stow; then
        print_status "${RED}" "stow is not installed. Please install it first."
        exit 1
    fi
    
    # Ensure bin directory exists
    if [[ ! -d "${BIN_DIR}" ]]; then
        print_status "${YELLOW}" "Creating binary directory: ${BIN_DIR}"
        mkdir -p "${BIN_DIR}"
    fi
}

# Run the stow simulation and handle the output
handle_simulation() {
    local simulation_output
    local default
    
    print_status "${YELLOW}" "Simulating stow operation..."
    
    if simulation_output=$(do_stow true); then
        print_status "${GREEN}" "Simulation successful! Here's what will happen:"
        echo "${simulation_output}"
        default="Y"
    else
        print_status "${RED}" "Simulation showed potential issues:"
        echo "${simulation_output}"
        default="N"
    fi
    
    echo "${default}"
}

# Execute the stow operation
execute_stow() {
    print_status "${GREEN}" "Proceeding with stow operation..."
    if do_stow false; then
        print_status "${GREEN}" "Configuration successfully installed!"
        return 0
    else
        print_status "${RED}" "Error occurred during stow operation"
        return 1
    fi
}

# Main function that orchestrates the configuration process
main() {
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -t|--type)
                if [[ -n "${2:-}" ]]; then
                    case "${2,,}" in
                        config|exec|all)
                            STOW_TYPE="${2,,}"
                            shift 2
                            ;;
                        *)
                            print_status "${RED}" "Invalid type: ${2}"
                            usage
                            exit 1
                            ;;
                    esac
                else
                    print_status "${RED}" "Missing type argument"
                    usage
                    exit 1
                fi
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                print_status "${RED}" "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done

    cd "$CONFIG_DIR"
    
    check_prerequisites
    
    local default
    default=$(handle_simulation)
    
    if get_user_confirmation "${default}"; then
        execute_stow || exit 1
    else
        print_status "${YELLOW}" "Operation cancelled by user"
        exit 0
    fi
}

# Execute main function with all script arguments
main "$@"
