#!/usr/bin/env bash

set -euo pipefail

# Script to install tmux and configuration
# Dependencies: tmux

CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMUX_CONFIG_SRC="${CONFIG_DIR}/config/dot-tmux.conf"
TMUX_CONFIG_DEST="${HOME}/.tmux.conf"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Print with color
print_status() {
    local color=$1
    shift
    printf "${color}%s${NC}\n" "$*"
}

# Check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Install tmux using the appropriate package manager
install_tmux() {
    if command_exists apt-get; then
        sudo apt-get update && sudo apt-get install -y tmux
    elif command_exists dnf; then
        sudo dnf install -y tmux
    elif command_exists yum; then
        sudo yum install -y tmux
    elif command_exists brew; then
        brew install tmux
    else
        print_status "${RED}" "No supported package manager found. Please install tmux manually."
        exit 1
    fi
}

# Main installation process
main() {
    # Check if tmux is installed
    if ! command_exists tmux; then
        print_status "${YELLOW}" "tmux is not installed. Installing..."
        install_tmux
    else
        print_status "${GREEN}" "tmux is already installed"
    fi

    # Backup existing config if it exists
    if [ -f "${TMUX_CONFIG_DEST}" ]; then
        print_status "${YELLOW}" "Backing up existing tmux config..."
        mv "${TMUX_CONFIG_DEST}" "${TMUX_CONFIG_DEST}.backup"
    fi

    # Install config file
    print_status "${GREEN}" "Installing tmux config..."
    cp "${TMUX_CONFIG_SRC}" "${TMUX_CONFIG_DEST}"

    print_status "${GREEN}" "tmux installation complete!"
    print_status "${GREEN}" "You may need to restart your terminal for changes to take effect."
}

main "$@"
