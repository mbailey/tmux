# Auto-attach to tmux session on terminal launch
#
# Behavior:
# - Local machine: First terminal attaches to "main", subsequent terminals stay bare
# - Remote machine (SSH): Always attach to "main" session
#
# This allows:
# - Primary local terminal in tmux for regular work
# - Additional local terminals bare for SSH (avoiding nested tmux)
# - Remote sessions automatically in tmux

# Check if we should auto-attach
_should_auto_attach_tmux() {
  # Don't attach if already in tmux
  [[ -n "$TMUX" ]] && return 1

  # Don't attach if TMUX_AUTO_ATTACH is explicitly disabled
  [[ "${TMUX_AUTO_ATTACH:-1}" == "0" ]] && return 1

  # If this is an SSH session, always attach
  if [[ -n "$SSH_CONNECTION" ]] || [[ -n "$SSH_CLIENT" ]]; then
    return 0
  fi

  # For local sessions, only attach if no other terminals are attached to main
  if tmux has-session -t main 2>/dev/null; then
    # Check if any clients are attached to main
    local attached_clients=$(tmux list-clients -t main 2>/dev/null | wc -l)
    if [[ $attached_clients -gt 0 ]]; then
      return 1  # Don't attach - main already has a client
    fi
  fi

  # Attach to main (will create if doesn't exist)
  return 0
}

# Auto-attach logic
if _should_auto_attach_tmux; then
  if tmux has-session -t main 2>/dev/null; then
    exec tmux attach-session -t main
  else
    exec tmux new-session -s main
  fi
fi
