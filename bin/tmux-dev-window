#!/usr/bin/env bash
set -euo pipefail

# tmux-dev-window - Create a 3-pane development layout in tmux
# Layout: editor (top-left), ai (top-right), shell (bottom)

show_help() {
  cat <<EOF
Usage: tmux-dev-window [OPTIONS] [PATH]

Create a tmux development window with 3-pane layout.

Arguments:
  PATH                Target directory or file (default: current directory)

Options:
  -w, --window NAME   Window name (default: directory name)
  -a, --ai CMD        AI command to run (default: see below)
  -t, --taskmaster    Enable Taskmaster Console pane (default: auto-detect)
  -T, --no-taskmaster Disable Taskmaster Console pane
  -h, --help          Show this help message

Default AI Command:
  1. If -a flag is provided, use that
  2. Else if \$TMUX_DEV_AI_CMD is set, use that
  3. Else if 'agents' command exists, use 'agents summon'
  4. Else if \$AI_COMMAND is set, use that (legacy)
  5. Else use 'claude'

Environment:
  TMUX_DEV_AI_CMD     Default AI command when not specified via -a
  TMUX_DEV_TMC        Enable TMC pane (set to 1 or 'true' to enable)
  EDITOR              Editor command (default: nvim --listen /tmp/nvim-cora)

Examples:
  tmux-dev-window                    # Current directory
  tmux-dev-window ~/project          # Specific directory
  tmux-dev-window -a "agents cora"   # Custom AI command
  tmux-dev-window -w backend .       # Custom window name
EOF
}

# Parse arguments
WINDOW_NAME=""
AI_CMD=""
TARGET_PATH=""
TMC_FLAG="" # Empty means auto-detect, "yes" means force on, "no" means force off

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help)
    show_help
    exit 0
    ;;
  -w | --window)
    WINDOW_NAME="$2"
    shift 2
    ;;
  -a | --ai)
    AI_CMD="$2"
    shift 2
    ;;
  -t | --taskmaster)
    TMC_FLAG="yes"
    shift
    ;;
  -T | --no-taskmaster)
    TMC_FLAG="no"
    shift
    ;;
  -*)
    echo "Unknown option: $1" >&2
    echo "Use -h for help" >&2
    exit 1
    ;;
  *)
    TARGET_PATH="$1"
    shift
    ;;
  esac
done

# Resolve target path
if [[ -z "$TARGET_PATH" ]]; then
  TARGET_DIR="$PWD"
else
  # Resolve symlinks and get absolute path
  TARGET_PATH="$(realpath "$TARGET_PATH")"
  if [[ -f "$TARGET_PATH" ]]; then
    # If it's a file, use its directory
    TARGET_DIR="$(dirname "$TARGET_PATH")"
  else
    TARGET_DIR="$TARGET_PATH"
  fi
fi

# Function to truncate window names (like show tool pattern)
truncate_window_name() {
  local name="$1"
  local max_len=25

  if [[ ${#name} -le $max_len ]]; then
    echo "$name"
    return
  fi

  # Truncate and use ~ as indicator (avoid dots for tmux target compatibility)
  echo "${name:0:$((max_len - 1))}~"
}

# Set defaults
WINDOW_NAME="${WINDOW_NAME:-$(truncate_window_name "${TARGET_DIR##*/}")}"

# Determine AI command default
if [[ -z "$AI_CMD" ]]; then
  if [[ -n "${TMUX_DEV_AI_CMD:-}" ]]; then
    AI_CMD="$TMUX_DEV_AI_CMD"
  elif command -v agents &>/dev/null; then
    AI_CMD="agents summon --no-tmux"
  elif [[ -n "${AI_COMMAND:-}" ]]; then
    AI_CMD="$AI_COMMAND"
  else
    AI_CMD="claude"
  fi
fi

EDITOR_CMD="${EDITOR:-nvim --listen /tmp/nvim-cora}"

# Determine if TMC pane should be enabled
ENABLE_TMC="no"
if [[ "$TMC_FLAG" == "yes" ]]; then
  ENABLE_TMC="yes"
elif [[ "$TMC_FLAG" == "no" ]]; then
  ENABLE_TMC="no"
elif [[ "${TMUX_DEV_TMC:-}" == "1" ]] || [[ "${TMUX_DEV_TMC:-}" == "true" ]]; then
  ENABLE_TMC="yes"
elif command -v tmc &>/dev/null; then
  # Auto-detect: enable if tmc command is available
  ENABLE_TMC="yes"
fi

# Ensure tmux server is running
if ! tmux info &>/dev/null; then
  # Start a detached tmux server
  tmux new-session -d -s _init
  tmux kill-session -t _init
fi

# Get tmux settings
PANE_BASE=$(tmux show-options -gv pane-base-index)

# Define pane identifiers
EDITOR_PANE="$PANE_BASE"
AI_PANE="$((PANE_BASE + 1))"
SHELL_PANE="$((PANE_BASE + 2))"
TMC_PANE="$((PANE_BASE + 3))"

# Check if window exists
if tmux list-windows -F '#{window_name}' | grep -q "^${WINDOW_NAME}$"; then
  echo "Window '$WINDOW_NAME' already exists, switching to it"
  tmux select-window -t "$WINDOW_NAME"
  exit 0
fi

# Create new window
tmux new-window -n "$WINDOW_NAME" -c "$TARGET_DIR"
tmux select-window -t "$WINDOW_NAME"

# Calculate bottom split percentage based on whether TMC is enabled
# With TMC: top 60%, shell 20%, tmc 20%
# Without TMC: top 75%, shell 25%
if [[ "$ENABLE_TMC" == "yes" ]]; then
  BOTTOM_SPLIT=40 # Shell + TMC together = 40%
else
  BOTTOM_SPLIT=25 # Shell only = 25%
fi

# Split horizontally for bottom panes
tmux split-window -v -p "$BOTTOM_SPLIT" -c "$TARGET_DIR"

# If TMC is enabled, split the bottom for shell and TMC
if [[ "$ENABLE_TMC" == "yes" ]]; then
  # We're in the bottom pane, split it (shell stays top 50%, tmc bottom 50%)
  tmux split-window -v -p 50 -c "$TARGET_DIR"
fi

# Select top pane and split vertically for AI (50/50)
tmux select-pane -t "$WINDOW_NAME.$EDITOR_PANE"
tmux split-window -h -p 50 -c "$TARGET_DIR"

# Name panes
tmux select-pane -t "$WINDOW_NAME.$EDITOR_PANE" -T "editor"
tmux select-pane -t "$WINDOW_NAME.$AI_PANE" -T "ai"
tmux select-pane -t "$WINDOW_NAME.$SHELL_PANE" -T "shell"
if [[ "$ENABLE_TMC" == "yes" ]]; then
  tmux select-pane -t "$WINDOW_NAME.$TMC_PANE" -T "tmc"
fi

# Wait for shells to initialize
sleep 1

# Send commands
tmux send-keys -t "$WINDOW_NAME.$EDITOR_PANE" "$EDITOR_CMD ." Enter

# Select AI pane first to ensure it opens there
tmux select-pane -t "$WINDOW_NAME.$AI_PANE"
tmux send-keys -t "$WINDOW_NAME.$AI_PANE" "$AI_CMD" Enter

# Start TMC if enabled
if [[ "$ENABLE_TMC" == "yes" ]]; then
  tmux send-keys -t "$WINDOW_NAME.$TMC_PANE" "tmc" Enter
fi

# Focus AI pane
tmux select-pane -t "$WINDOW_NAME.$AI_PANE"

echo "Created development window: $WINDOW_NAME"
if [[ "$ENABLE_TMC" == "yes" ]]; then
  echo "  (with Taskmaster Console)"
fi
