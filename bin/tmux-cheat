#!/usr/bin/env bash
set -o nounset -o pipefail -o errexit

# Get absolute path to script directory
command -v realpath &> /dev/null || {
    echo "Error: 'realpath' is required but not found. Please install 'coreutils' (e.g. 'brew install coreutils' on macOS)." >&2
    exit 1
}
SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
DOCS_DIR="$(dirname "$SCRIPT_DIR")"/docs

# Get terminal width to determine display format
TERM_WIDTH=$(tput cols 2>/dev/null || echo 80)

# Function to format the cheat sheet based on terminal width
format_cheatsheet() {
    local cheatsheet="$1"
    
    if [ "$TERM_WIDTH" -lt 60 ]; then
        # For very narrow terminals, use a compact format
        echo "$cheatsheet" | sed 's/  / /g'
    else
        # For normal terminals, use standard format
        echo "$cheatsheet"
    fi
}

# Display the cheat sheet with less
format_cheatsheet "$(cat "$DOCS_DIR/cheat.md")" | less -FXR
