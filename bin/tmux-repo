#!/usr/bin/env bash
# tmux-repo - Create/attach to tmux session named after current git repo
#
# Usage: tmux-repo [session-name]
#
# If no session name given, uses the current git repo name.
# If not in a git repo, falls back to "main" session.
# Changes to the repo root directory (or $HOME if no repo).

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || true
session_name="${1:-}"

if [[ -z "$session_name" ]]; then
    if [[ -n "$repo_root" ]]; then
        session_name=$(basename "$repo_root")
    else
        session_name="main"
        repo_root="$HOME"
    fi
fi

work_dir="${repo_root:-$HOME}"

# Use "=" prefix for exact session name matching (tmux does prefix matching by default,
# so "voicemode" would match "voicemode-connect" without it)
if [[ -n "${TMUX:-}" ]]; then
    if ! tmux has-session -t "=$session_name" 2>/dev/null; then
        tmux new-session -ds "$session_name" -c "$work_dir"
    fi
    exec tmux switch-client -t "=$session_name"
fi

exec tmux new-session -As "$session_name" -c "$work_dir"
