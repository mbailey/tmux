#!/usr/bin/env bash
set -o nounset -o pipefail -o errexit

# Function to copy using OSC 52 escape sequence
osc52_copy() {
    buf=$(cat)
    encoded=$(printf %s "$buf" | base64)
    printf "\033]52;c;%s\007" "$encoded"
}

# Function to copy to system clipboard
system_copy() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        tee >(pbcopy) | osc52_copy
    elif command -v wl-copy >/dev/null 2>&1; then
        wl-copy
    elif command -v xclip >/dev/null 2>&1; then
        xclip -in -selection clipboard
    else
        tmux load-buffer -
    fi
}

# On macOS, we want to copy both to pbcopy and send via OSC 52
# since we're likely SSH'd in from Linux
if [[ "$OSTYPE" == "darwin"* ]]; then
    system_copy
else
    # For other systems, check if we're in SSH
    if [[ -n "${SSH_CLIENT:-}" ]] || [[ -n "${SSH_TTY:-}" ]]; then
        osc52_copy
    else
        system_copy
    fi
fi
